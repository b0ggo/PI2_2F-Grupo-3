# Copie para .env na raiz do projeto e ajuste os valores antes do deploy.
# Gerar SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"

# --- PostgreSQL ---
POSTGRES_USER=agrogestor
POSTGRES_PASSWORD=ALTERE-ESTA-SENHA-FORTE
POSTGRES_DB=agrogestor

# --- Backend (Flask + Gunicorn) ---
DATABASE_URL=postgresql+psycopg2://agrogestor:ALTERE-ESTA-SENHA-FORTE@db:5432/agrogestor
SECRET_KEY=ALTERE-PARA-UMA-CHAVE-ALEATORIA-COM-PELO-MENOS-32-CARACTERES
CORS_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br
APP_ENV=production
FLASK_DEBUG=0
GUNICORN=1
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120

# --- Frontend ---
# Deixe vazio quando Nginx faz proxy de /api no mesmo domínio (recomendado).
# Preencha apenas se a API estiver em outro domínio (ex.: https://api.seudominio.com.br).
VITE_API_URL=

# --- Rede ---
HTTP_PORT=80
