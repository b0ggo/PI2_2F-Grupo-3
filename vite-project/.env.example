# Desenvolvimento: deixe vazio para usar o proxy do Vite (/api -> backend)
VITE_API_URL=

# Alvo do proxy em dev local (padrão: http://localhost:5000)
# No Docker Compose dev isso é definido como http://backend:5000
# VITE_PROXY_TARGET=http://localhost:5000

# Produção: deixe vazio se Nginx faz proxy de /api no mesmo domínio.
# Só preencha se a API estiver em outro host (ex.: https://api.seudominio.com.br).
